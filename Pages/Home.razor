@page "/"

<PageTitle>Home</PageTitle>

<div class="landing-page">
    <header class="site-header">
        <div class="container section-row">
            <a class="brand" href="#home">
                <span class="brand-mark"></span>
                <span>
                    <span class="brand-title">JACKSON</span>
                    <span class="brand-subtitle">PRO WELDING</span>
                </span>
            </a>

            <nav class="site-nav">
                <a href="#home">Home</a>
                <a href="#services">Services</a>
                <a href="#projects">Projects</a>
                <a href="#about">About</a>
                <a href="#contact">Contact</a>
            </nav>

            <a class="button button-primary header-cta" href="#contact">Get a Free Estimate</a>
        </div>
    </header>

    <main>
        <section class="hero-section" id="home">
            <div class="container hero-grid">
                <div class="hero-copy">
                    <span class="eyebrow">Professional Metalwork</span>
                    <h1>Professional <span>Welding</span> Services</h1>
                    <p>
                        Custom fabrication, repairs, aluminum, stainless steel and on-site welding
                        done right with quality, speed and attention to detail.
                    </p>

                    <div class="hero-actions">
                        <a class="button button-primary" href="#contact">Get a Free Estimate</a>
                        <a class="button button-secondary" href="#projects">View Projects</a>
                    </div>

                    <div class="hero-highlights">
                        <div><strong>Mobile Service</strong><span>On-site support when you need it</span></div>
                        <div><strong>Licensed &amp; Insured</strong><span>Reliable and professional workmanship</span></div>
                        <div><strong>Quality Guaranteed</strong><span>Built to last with clean finishes</span></div>
                    </div>
                </div>

                <div class="hero-visual visual-panel">
                    <img src="/img/banner.jpg" alt="Jackson Pro Welding" class="visual-panel-img" />
                </div>
            </div>
        </section>

        <section class="about-section" id="about">
            <div class="container split-section">
                <div class="visual-panel about-visual">
                    <img src="/img/banner2.jpg" alt="About Jackson Pro Welding" class="visual-panel-img" />
                </div>

                <div class="section-copy">
                    <span class="eyebrow">About</span>
                    <h2>Built on precision.</h2>
                    <p>
                        Jackson Pro Welding delivers high-quality welding and metal fabrication for
                        residential, commercial and industrial customers. Every project is completed
                        with durability, clean execution and professional service.
                    </p>

                    <div class="stats-grid">
                        <div><strong>500+</strong><span>Projects</span></div>
                        <div><strong>10+</strong><span>Years Experience</span></div>
                        <div><strong>100%</strong><span>Customer Satisfaction</span></div>
                    </div>
                </div>
            </div>
        </section>

        <section class="services-section" id="services">
            <div class="container">
                <span class="eyebrow">Services</span>
                <h2>What we do</h2>

                <div class="services-grid">
                    <article class="info-card">
                        <h3>Mobile Welding</h3>
                        <p>On-site repair and welding services for fast response and convenience.</p>
                    </article>
                    <article class="info-card">
                        <h3>Steel Fabrication</h3>
                        <p>Custom-built metal pieces for structural, residential and business needs.</p>
                    </article>
                    <article class="info-card">
                        <h3>Aluminum Welding</h3>
                        <p>Professional TIG and MIG welding for clean, durable aluminum work.</p>
                    </article>
                    <article class="info-card">
                        <h3>Stainless Steel</h3>
                        <p>Food-grade and decorative stainless steel projects with quality finishes.</p>
                    </article>
                    <article class="info-card">
                        <h3>Repairs</h3>
                        <p>Gates, trailers, railings, equipment and general metal repair services.</p>
                    </article>
                    <article class="info-card">
                        <h3>Custom Projects</h3>
                        <p>Fabrication for frames, furniture, railings, gates and specialty builds.</p>
                    </article>
                </div>
            </div>
        </section>

        <section class="projects-section" id="projects">
            <div class="container">
                <span class="eyebrow">Projects</span>
                <div class="section-heading">
                    <h2>Recent work</h2>
                    <a class="button button-secondary" href="#contact">View All Projects</a>
                </div>

                <div class="projects-grid">
                    <div class="project-card"><img src="img/projects/stairs.jpg" alt="Stairs Project" /><span>Stairs Project</span></div>
                    <div class="project-card"><span>Security Gate</span></div>
                    <div class="project-card"><img src="img/projects/trailerbuild.jpg" alt="Trailer Build" /><span>Trailer Build</span></div>
                    <div class="project-card"><span>Custom Rails</span></div>
                    <div class="project-card"><img src="img/projects/shopfabrication.jpg" alt="Shop Fabrication" /><span>Shop Fabrication</span></div>
                </div>
            </div>
        </section>

        <section class="testimonials-section">
            <div class="container">
                <span class="eyebrow">Testimonials</span>
                <h2>What clients say</h2>

                <div class="testimonials-grid">
                    <article class="testimonial-card">
                        <span class="stars">★★★★★</span>
                        <p>
                            Jackson did an amazing job on our gate. Strong, clean and professional
                            work from start to finish.
                        </p>
                        <strong>Michael R.</strong>
                    </article>
                    <article class="testimonial-card">
                        <span class="stars">★★★★★</span>
                        <p>
                            Very reliable and always on time. The final welds and finish quality were
                            excellent.
                        </p>
                        <strong>Sarah T.</strong>
                    </article>
                    <article class="testimonial-card">
                        <span class="stars">★★★★★</span>
                        <p>
                            Best welder we've worked with. Great communication, fair pricing and
                            outstanding craftsmanship.
                        </p>
                        <strong>David L.</strong>
                    </article>
                </div>
            </div>
        </section>
    </main>

    <section class="contact-section" id="contact">
        <div class="container contact-grid">

            <div class="contact-info">
                <span class="eyebrow">Get in Touch</span>
                <h2>Let's Talk About <span class="contact-accent">Your Project</span></h2>
                <p class="contact-lead">Have a project in mind or need a repair? Contact Jackson Pro Welding today for a free estimate.</p>

                <div class="contact-items">
                    <div class="contact-item">
                        <span class="contact-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.79 19.79 0 0 1 11.27 19a19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        </span>
                        <div>
                            <strong>Call Us</strong>
                            <a href="tel:+12311234567" class="contact-value">(231) 123-4567</a>
                        </div>
                    </div>

                    <div class="contact-item">
                        <span class="contact-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                        </span>
                        <div>
                            <strong>Email Us</strong>
                            <a href="mailto:info@jacksonprowelding.com" class="contact-value">info@jacksonprowelding.com</a>
                        </div>
                    </div>

                    <div class="contact-item">
                        <span class="contact-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        </span>
                        <div>
                            <strong>Service Areas</strong>
                            <span class="contact-value">
                                Brevard County, FL<br />
                                Indian River County, FL<br />
                                Volusia County, FL<br />
                                &amp; Surrounding Areas
                            </span>
                        </div>
                    </div>

                    <div class="contact-item">
                        <span class="contact-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        </span>
                        <div>
                            <strong>Hours</strong>
                            <span class="contact-value">
                                Mon - Sat: 7:00 AM – 6:00 PM<br />
                                Sunday: Closed
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="contact-form-panel">
                @if (_formSubmitted)
                {
                    <div class="form-success">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        <h3>Message Sent!</h3>
                        <p>Thank you for reaching out. We'll get back to you shortly.</p>
                    </div>
                }
                else
                {
                    <div class="form-row">
                        <div class="form-field">
                            <input type="text" placeholder="Full Name" @bind="_formName" />
                        </div>
                        <div class="form-field">
                            <input type="tel" placeholder="Phone Number" @bind="_formPhone" />
                        </div>
                    </div>

                    <div class="form-field">
                        <input type="email" placeholder="Email Address" @bind="_formEmail" />
                    </div>

                    <div class="form-field">
                        <select @bind="_formService">
                            <option value="" disabled selected>Service Needed</option>
                            <option value="mobile-welding">Mobile Welding</option>
                            <option value="steel-fabrication">Steel Fabrication</option>
                            <option value="aluminum-welding">Aluminum Welding</option>
                            <option value="stainless-steel">Stainless Steel</option>
                            <option value="repairs">Repairs</option>
                            <option value="custom-project">Custom Project</option>
                        </select>
                    </div>

                    <div class="form-field">
                        <textarea placeholder="Project Details" rows="5" @bind="_formDetails"></textarea>
                    </div>

                    <label class="upload-area" for="photoUpload">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
                        <strong>Upload Photos (Optional)</strong>
                        <span>@(_uploadedFiles.Count > 0 ? $"{_uploadedFiles.Count} file(s) selected" : "Drag & drop or click to upload")</span>
                        <InputFile id="photoUpload" multiple accept="image/*" OnChange="HandleFileSelection" style="display:none" />
                    </label>

                    @if (!string.IsNullOrWhiteSpace(_validationError))
                    {
                        <p class="form-error">@_validationError</p>
                    }

                    <button class="button button-primary contact-submit" @onclick="SubmitForm">Send Message</button>

                    <p class="form-privacy">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        We respect your privacy. Your information will never be shared.
                    </p>
                }
            </div>

            <div class="contact-aside">
                <div class="contact-image visual-panel">
                    <img src="/img/banner3.png" alt="Jackson Pro Welding" class="visual-panel-img" />
                </div>

                <div class="contact-badges">
                    <div class="contact-badge">
                        <span class="badge-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                        </span>
                        <div>
                            <strong>Licensed &amp; Insured</strong>
                            <span>Your project is in safe hands.</span>
                        </div>
                    </div>

                    <div class="contact-badge">
                        <span class="badge-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
                        </span>
                        <div>
                            <strong>Quality Guaranteed</strong>
                            <span>We stand behind our work.</span>
                        </div>
                    </div>

                    <div class="contact-badge">
                        <span class="badge-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                        </span>
                        <div>
                            <strong>Mobile Service</strong>
                            <span>We come to you.</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <footer class="site-footer">

        <div class="container footer-grid">
            <div>
                <a class="brand footer-brand" href="#home">
                    <span class="brand-mark"></span>
                    <span>
                        <span class="brand-title">JACKSON</span>
                        <span class="brand-subtitle">PRO WELDING</span>
                    </span>
                </a>
                <p>Serving your area with dependable welding and fabrication services.</p>
            </div>

            <div>
                <h3>Contact</h3>
                <p>(231) 123-4567</p>
                <p>info@jacksonprowelding.com</p>
            </div>

            <div>
                <h3>Service Areas</h3>
                <p>Brevard County, FL</p>
                <p>Indian River County, FL</p>
                <p>Volusia County, FL</p>
            </div>

            <div>
                <h3>Follow Us</h3>
                <div class="social-links">
                    <a class="social-link" href="https://www.facebook.com/profile.php?id=61574418192454" target="_blank" rel="noopener noreferrer">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                        Facebook
                    </a>
                    <a class="social-link" href="https://www.instagram.com/jacksonprowelding/" target="_blank" rel="noopener noreferrer">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
                        Instagram
                    </a>
                </div>
            </div>
        </div>
    </footer>
</div>

@code {
    private bool _formSubmitted = false;
    private string _formName = "";
    private string _formPhone = "";
    private string _formEmail = "";
    private string _formService = "";
    private string _formDetails = "";
    private string _validationError = "";
    private List<IBrowserFile> _uploadedFiles = new();

    private void HandleFileSelection(InputFileChangeEventArgs e)
    {
        _uploadedFiles = e.GetMultipleFiles(10).ToList();
    }

    private void SubmitForm()
    {
        if (string.IsNullOrWhiteSpace(_formName) || string.IsNullOrWhiteSpace(_formEmail) || string.IsNullOrWhiteSpace(_formPhone))
        {
            _validationError = "Please fill in your name, phone number and email address.";
            return;
        }
        _validationError = "";
        _formSubmitted = true;
    }
}
